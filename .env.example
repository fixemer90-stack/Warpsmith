# ── WH40k Battle Simulator — Environment ─────────────────────────
# Скопируй в .env перед запуском. Не коммить .env в репозиторий!

# Режим: true → production (bcrypt, Secure cookie, 0.0.0.0)
#         false / пусто → dev (localhost, guest access)
HOSTING=true

# JWT секрет — сгенерировать:
#   python3 -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=change-me-in-production-2026

# Срок действия JWT в днях
JWT_EXPIRE_DAYS=7

# Разрешённые CORS-источники (через запятую)
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Хост и порт для uvicorn
HOST=0.0.0.0
PORT=8000

# Путь к SQLite БД
DB_PATH=/data/simulator.db

# Logging
LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
SENTRY_DSN=              # https://key@sentry.io/project
